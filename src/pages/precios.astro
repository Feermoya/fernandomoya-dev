<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Precios — FERMOYADEV</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #080809;
      --surface: #101013;
      --surface2: #18181d;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --text: #f0f0f2;
      --muted: #6b6b78;
      --muted2: #9898a6;
      --accent-v: #8B5CF6;
      --dot-b: #525260;
      --dot-m: #FBBF24;
      --dot-p: #8B5CF6;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* LOGIN */
    #login-screen {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; padding: 1.5rem;
    }
    .login-logo {
      font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 2.5rem;
    }
    .login-box {
      width: 100%; max-width: 360px; background: var(--surface);
      border: 1px solid var(--border); border-radius: 20px; padding: 2.2rem 2rem;
    }
    .login-box h1 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
    .login-box p  { font-size: 13px; color: var(--muted2); margin-bottom: 2rem; }
    .field-label  {
      font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 8px; display: block;
    }
    .pass-wrap { position: relative; margin-bottom: 1.2rem; }
    input[type="password"], input[type="text"] {
      width: 100%; background: var(--bg); border: 1px solid var(--border2);
      border-radius: 12px; color: var(--text); font-family: inherit;
      font-size: 15px; padding: 13px 44px 13px 16px; outline: none; transition: border-color 0.2s;
    }
    input:focus { border-color: var(--accent-v); }
    .eye-btn {
      position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: var(--muted);
      display: flex; align-items: center; padding: 0;
    }
    .btn-primary {
      width: 100%; background: var(--accent-v); color: #fff; border: none;
      border-radius: 12px; font-family: inherit; font-size: 15px; font-weight: 600;
      padding: 13px; cursor: pointer; transition: opacity 0.15s, transform 0.1s;
    }
    .btn-primary:hover { opacity: 0.88; }
    .btn-primary:active { transform: scale(0.98); }
    .login-error { font-size: 12.5px; color: #f87171; margin-top: 10px; display: none; }

    /* CONTENT */
    #content-screen { display: none; min-height: 100vh; padding-bottom: 4rem; }

    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; background: rgba(8,8,9,0.9);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 10;
    }
    .topbar-brand {
      font-size: 12px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--muted2);
    }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .badge-private {
      font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--accent-v); background: rgba(139,92,246,0.1);
      border: 1px solid rgba(139,92,246,0.2); border-radius: 20px; padding: 3px 10px;
    }
    .btn-small {
      background: none; border: 1px solid var(--border2); border-radius: 8px;
      color: var(--muted); font-family: inherit; font-size: 12px;
      padding: 5px 11px; cursor: pointer; transition: color 0.15s, background 0.15s;
      display: flex; align-items: center; gap: 4px; white-space: nowrap;
    }
    .btn-small:hover { color: var(--text); }
    .btn-small.active { background: var(--surface2); color: var(--muted2); border-color: var(--border2); }

    .main { max-width: 680px; margin: 0 auto; padding: 2rem 1.25rem 0; }
    .page-eyebrow {
      font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 4px;
    }
    .page-title { font-size: 24px; font-weight: 700; margin-bottom: 1.75rem; line-height: 1.2; }

    .section-label {
      font-size: 10px; font-weight: 600; letter-spacing: 0.13em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 8px; margin-top: 1.5rem;
      display: flex; align-items: center; gap: 10px;
    }
    .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    .service-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; margin-bottom: 8px;
    }
    .card-head {
      display: flex; align-items: flex-start; justify-content: space-between;
      padding: 14px 16px 12px; border-bottom: 1px solid var(--border); gap: 10px;
    }
    .card-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .card-sub   { font-size: 11px; color: var(--muted2); line-height: 1.45; }
    .tag {
      font-size: 10px; font-weight: 600; letter-spacing: 0.04em;
      padding: 2px 8px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; margin-top: 1px;
    }
    .tag-v { background: rgba(139,92,246,0.1); color: #a78bfa; }
    .tag-b { background: rgba(59,130,246,0.1);  color: #93c5fd; }
    .tag-g { background: rgba(16,185,129,0.1);  color: #6ee7b7; }

    .tiers { display: grid; grid-template-columns: repeat(3, 1fr); }
    .tier { padding: 12px 14px; border-right: 1px solid var(--border); }
    .tier:last-child { border-right: none; }
    .tier-name {
      display: flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 5px;
    }
    .dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
    .dot-basic { background: var(--dot-b); }
    .dot-medio { background: var(--dot-m); }
    .dot-pro   { background: var(--dot-p); }
    .tier-name-basic { color: var(--muted2); }
    .tier-name-medio { color: #d4a012; }
    .tier-name-pro   { color: #a78bfa; }
    .tier-price { font-size: 13px; font-weight: 700; color: var(--text); line-height: 1.3; }

    .mant-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden;
    }
    .mant-row {
      display: grid; grid-template-columns: 74px 1fr auto;
      align-items: center; gap: 12px; padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }
    .mant-row:last-child { border-bottom: none; }
    .mant-plan {
      display: flex; align-items: center; gap: 6px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    }
    .mant-plan-basic { color: var(--muted2); }
    .mant-plan-medio { color: #d4a012; }
    .mant-plan-pro   { color: #a78bfa; }
    .mant-inc   { font-size: 11.5px; color: var(--muted2); line-height: 1.45; }
    .mant-price { text-align: right; font-size: 12px; font-weight: 700; color: var(--text); white-space: nowrap; }
    .mant-usd   { font-size: 10px; color: var(--muted); font-weight: 400; margin-top: 2px; }

    .nota {
      font-size: 11px; color: var(--muted); background: var(--surface2);
      border-radius: 10px; padding: 10px 13px; margin-top: 12px; line-height: 1.6;
    }
    .nota strong { color: var(--muted2); font-weight: 600; }

    /* ══════════════════════════════════════════
       MODO COMPACTO — cabe en una screenshot
    ══════════════════════════════════════════ */
    body.compact .main         { padding: 0.75rem 0.65rem 0; }
    body.compact .topbar       { padding: 9px 12px; }
    body.compact .page-eyebrow { display: none; }
    body.compact .page-title   { font-size: 15px; margin-bottom: 0.75rem; }
    body.compact .section-label{ font-size: 8.5px; margin-top: 0.75rem; margin-bottom: 5px; }

    body.compact .service-card { border-radius: 9px; margin-bottom: 4px; }
    body.compact .card-head    { padding: 7px 10px; gap: 8px; }
    body.compact .card-title   { font-size: 10.5px; margin-bottom: 1px; }
    body.compact .card-sub     { font-size: 9px; }
    body.compact .tag          { font-size: 8.5px; padding: 1px 6px; }

    body.compact .tier         { padding: 6px 9px; }
    body.compact .tier-name    { font-size: 8px; margin-bottom: 3px; gap: 3px; }
    body.compact .dot          { width: 4px; height: 4px; }
    body.compact .tier-price   { font-size: 10.5px; }

    body.compact .mant-card    { border-radius: 9px; }
    body.compact .mant-row     { padding: 7px 10px; gap: 6px; grid-template-columns: 54px 1fr auto; }
    body.compact .mant-plan    { font-size: 8.5px; gap: 4px; }
    body.compact .mant-inc     { font-size: 9.5px; }
    body.compact .mant-price   { font-size: 10.5px; }
    body.compact .mant-usd     { font-size: 8.5px; }

    body.compact .nota         { font-size: 9px; padding: 6px 9px; margin-top: 6px; border-radius: 7px; }

    /* responsive normal */
    @media (max-width: 540px) {
      body:not(.compact) .tiers { grid-template-columns: 1fr; }
      body:not(.compact) .tier  { border-right: none; border-bottom: 1px solid var(--border); }
      body:not(.compact) .tier:last-child { border-bottom: none; }
      body:not(.compact) .mant-row { grid-template-columns: 1fr; gap: 3px; }
      body:not(.compact) .mant-price { text-align: left; }
      body:not(.compact) .card-head  { flex-direction: column; }
    }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-logo">Fermoyadev</div>
  <div class="login-box">
    <h1>Acceso privado</h1>
    <p>Esta sección es solo para uso interno.</p>
    <label class="field-label" for="pass">Contraseña</label>
    <div class="pass-wrap">
      <input type="password" id="pass" placeholder="••••••••••" autocomplete="off" />
      <button class="eye-btn" id="eye-btn" type="button" aria-label="Ver contraseña">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
    </div>
    <button class="btn-primary" id="login-btn">Entrar</button>
    <div class="login-error" id="login-error">Contraseña incorrecta. Intentá de nuevo.</div>
    <a href="/" style="display:block;text-align:center;margin-top:1.5rem;font-size:13px;color:var(--muted2);text-decoration:none;">← Volver al inicio</a>
  </div>
</div>

<!-- CONTENT -->
<div id="content-screen">
  <div class="topbar">
    <span class="topbar-brand">Fermoyadev</span>
    <div class="topbar-right">
      <span class="badge-private">Privado</span>
      <button class="btn-small" id="compact-btn">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.9" viewBox="0 0 24 24">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        </svg>
        <span id="compact-label">Compacto</span>
      </button>
      <button class="btn-small" id="logout-btn">Salir</button>
    </div>
  </div>

  <div class="main">
    <p class="page-eyebrow">Panel de precios</p>
    <h2 class="page-title">Servicios web</h2>

    <div class="section-label">Desarrollo</div>

    <div class="service-card">
      <div class="card-head">
        <div>
          <div class="card-title">Landing page</div>
          <div class="card-sub">1 página · 4–6 secciones · 1 cambio chico/mes · hosting incluido</div>
        </div>
        <span class="tag tag-v">1 página</span>
      </div>
      <div class="tiers">
        <div class="tier">
          <div class="tier-name tier-name-basic"><span class="dot dot-basic"></span>Básico</div>
          <div class="tier-price">$250k – $350k</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-medio"><span class="dot dot-medio"></span>Medio</div>
          <div class="tier-price">$350k – $500k</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-pro"><span class="dot dot-pro"></span>Pro</div>
          <div class="tier-price">$500k – $700k</div>
        </div>
      </div>
    </div>

    <div class="service-card">
      <div class="card-head">
        <div>
          <div class="card-title">Web institucional</div>
          <div class="card-sub">Multi página · Home + 3 a 6 secciones · hasta 3 cambios/mes</div>
        </div>
        <span class="tag tag-b">Multi página</span>
      </div>
      <div class="tiers">
        <div class="tier">
          <div class="tier-name tier-name-basic"><span class="dot dot-basic"></span>Básico</div>
          <div class="tier-price">$400k – $700k</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-medio"><span class="dot dot-medio"></span>Medio</div>
          <div class="tier-price">$700k – $1.2M</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-pro"><span class="dot dot-pro"></span>Pro</div>
          <div class="tier-price">$1.2M – $2M</div>
        </div>
      </div>
    </div>

    <div class="service-card">
      <div class="card-head">
        <div>
          <div class="card-title">Catálogo / E-commerce sin pago</div>
          <div class="card-sub">Productos + filtros + estructura dinámica · sin pasarela de pago</div>
        </div>
        <span class="tag tag-g">Dinámico</span>
      </div>
      <div class="tiers">
        <div class="tier">
          <div class="tier-name tier-name-basic"><span class="dot dot-basic"></span>Básico</div>
          <div class="tier-price">$800k – $1.5M</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-medio"><span class="dot dot-medio"></span>Medio</div>
          <div class="tier-price">$1.5M – $2.5M</div>
        </div>
        <div class="tier">
          <div class="tier-name tier-name-pro"><span class="dot dot-pro"></span>Pro</div>
          <div class="tier-price">$2.5M – $4M</div>
        </div>
      </div>
    </div>

    <div class="section-label">Mantenimiento mensual</div>

    <div class="mant-card">
      <div class="mant-row">
        <div class="mant-plan mant-plan-basic"><span class="dot dot-basic"></span>Básico</div>
        <div class="mant-inc">Hosting · deploy · 1 cambio chico/mes</div>
        <div class="mant-price">$30k – $50k<div class="mant-usd">USD 30–45</div></div>
      </div>
      <div class="mant-row">
        <div class="mant-plan mant-plan-medio"><span class="dot dot-medio"></span>Medio</div>
        <div class="mant-inc">Todo lo anterior · hasta 3 cambios chicos/mes</div>
        <div class="mant-price">$50k – $80k<div class="mant-usd">USD 50–80</div></div>
      </div>
      <div class="mant-row">
        <div class="mant-plan mant-plan-pro"><span class="dot dot-pro"></span>Pro</div>
        <div class="mant-inc">Diseño avanzado · animaciones · SEO · prioridad alta</div>
        <div class="mant-price">A convenir</div>
      </div>
    </div>

    <div class="nota">
      <strong>Cambios chicos:</strong> textos, imágenes y ajustes visuales menores. No incluyen nuevas secciones ni funcionalidades.
    </div>
  </div>
</div>

<script>
  const PASSWORD    = "moya2025";
  const KEY         = "fx_authed";
  const COMPACT_KEY = "fx_compact";

  const login       = document.getElementById("login-screen");
  const content     = document.getElementById("content-screen");
  const passInput   = document.getElementById("pass");
  const loginBtn    = document.getElementById("login-btn");
  const loginError  = document.getElementById("login-error");
  const logoutBtn   = document.getElementById("logout-btn");
  const eyeBtn      = document.getElementById("eye-btn");
  const compactBtn  = document.getElementById("compact-btn");
  const compactLbl  = document.getElementById("compact-label");

  function show(authed) {
    login.style.display   = authed ? "none"  : "flex";
    content.style.display = authed ? "block" : "none";
  }

  function setCompact(on) {
    document.body.classList.toggle("compact", on);
    compactBtn.classList.toggle("active", on);
    compactLbl.textContent = on ? "Normal" : "Compacto";
    localStorage.setItem(COMPACT_KEY, on ? "1" : "0");
  }

  // init
  show(localStorage.getItem(KEY) === "1");
  if (localStorage.getItem(COMPACT_KEY) === "1") setCompact(true);

  loginBtn.addEventListener("click", () => {
    if (passInput.value === PASSWORD) {
      localStorage.setItem(KEY, "1");
      loginError.style.display = "none";
      show(true);
    } else {
      loginError.style.display = "block";
      passInput.value = "";
      passInput.focus();
    }
  });

  passInput.addEventListener("keydown", e => { if (e.key === "Enter") loginBtn.click(); });

  logoutBtn.addEventListener("click", () => {
    localStorage.removeItem(KEY);
    show(false);
    passInput.value = "";
  });

  eyeBtn.addEventListener("click", () => {
    passInput.type = passInput.type === "password" ? "text" : "password";
  });

  compactBtn.addEventListener("click", () => {
    setCompact(!document.body.classList.contains("compact"));
  });
</script>
</body>
</html>