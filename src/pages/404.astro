---
import Layout from '@/layouts/Layout.astro';
import NotFoundClient from '@/components/react/NotFoundClient';
import { pageTitle } from '@/utils/seo';

const title = pageTitle('No encontrado');
const description = 'La página que buscás no existe o fue movida.';
---

<Layout title={title} description={description} path="/404" noindex>
  <NotFoundClient client:load />
</Layout>
