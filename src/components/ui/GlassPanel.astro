---
interface Props {
  as?: 'div' | 'section' | 'article';
  class?: string;
  variant?: 'default' | 'soft';
}

const { as: Tag = 'div', class: className = '', variant = 'default' } = Astro.props;
const surface = variant === 'soft' ? 'glass-surface-sm' : 'glass-panel';
---

<Tag class={`${surface} rounded-xl p-6 sm:p-8 ${className}`}>
  <slot />
</Tag>
