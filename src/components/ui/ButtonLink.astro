---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost';
  class?: string;
  external?: boolean;
}

const { href, variant = 'primary', class: className = '', external = false } = Astro.props;

const base =
  'inline-flex min-h-[44px] items-center justify-center gap-2 rounded-lg px-5 py-2.5 text-sm font-medium transition-[transform,box-shadow,background-color,border-color,color] duration-200 ease-out focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 active:scale-[0.99] motion-reduce:transition-none motion-reduce:active:scale-100';

const styles =
  variant === 'primary'
    ? 'border border-transparent bg-accent text-white shadow-sm hover:bg-accent-hover'
    : 'border border-transparent text-muted hover:border-border/70 hover:bg-white/45 hover:text-text hover:shadow-sm';

const isHash = href.startsWith('#');
const isMailto = href.startsWith('mailto:');
const attrs = {
  ...(external ? { target: '_blank' as const, rel: 'noopener noreferrer' as const } : {}),
  ...(!external && !isHash && !isMailto ? { 'data-astro-prefetch': true } : {}),
};
---

<a href={href} class={`${base} ${styles} ${className}`} {...attrs}>
  <slot />
</a>
