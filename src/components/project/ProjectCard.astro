---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getProjectCover } from '@/utils/images';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, id } = project;
const cover = getProjectCover(data.cover);
const kindLabel = data.kind === 'client' ? 'Cliente' : 'Propio';
const live = data.links.live;
---

<article id={`proyecto-${id}`} class="glass-surface glass-card group flex flex-col overflow-hidden rounded-2xl">
  <div>
    <div class="relative aspect-[16/10] overflow-hidden bg-surface-2/80">
      {
        cover ? (
          <Image
            src={cover}
            alt={`Vista del proyecto ${data.title}`}
            width={800}
            height={500}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 ease-out motion-reduce:transition-none group-hover:scale-[1.02] motion-reduce:group-hover:scale-100"
            sizes="(min-width: 1280px) 22vw, (min-width: 640px) 45vw, 100vw"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-surface-2 text-xs text-muted">
            Sin imagen
          </div>
        )
      }
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-surface-0/88 via-transparent to-white/12"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/50 to-transparent opacity-80"
        aria-hidden="true"
      />
    </div>

    <div class="border-t border-white/35 bg-white/18 px-5 pb-5 pt-5 sm:px-6 sm:pt-6">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 border-b border-border/25 pb-3">
        <span class="text-[11px] font-medium uppercase tracking-wide text-muted">{kindLabel}</span>
        <span class="text-border-strong/70" aria-hidden="true">
          ·
        </span>
        <span class="text-[11px] text-muted">{data.projectType}</span>
      </div>
      <h3 class="mt-3 text-lg font-semibold tracking-tight text-text">{data.title}</h3>
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted">{data.description}</p>
      <div class="mt-4 rounded-lg bg-white/35 px-3 py-2 ring-1 ring-black/[0.04]">
        <p class="text-[11px] leading-relaxed tracking-wide text-muted">
          <span class="font-medium text-text/85">Stack</span>
          <span class="mx-1.5 text-border-strong/60" aria-hidden="true">
            ·
          </span>
          <span>{data.stack.join(' · ')}</span>
        </p>
      </div>
    </div>
  </div>

  <div
    class="glass-surface-sm mt-auto flex flex-wrap gap-2 border-t border-border/30 px-5 py-4 sm:px-6"
    role="group"
    aria-label="Acciones del proyecto"
  >
    <a
      href={live}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-transparent bg-accent px-3 py-2.5 text-center text-xs font-medium text-white shadow-sm transition hover:bg-accent-hover"
    >
      Sitio en vivo
      <span aria-hidden="true" class="opacity-80">↗</span>
    </a>
  </div>
</article>
