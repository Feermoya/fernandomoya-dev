---
import AboutSectionClient from '@/components/react/AboutSectionClient';
import { PLACEHOLDER_BIO } from '@/data/placeholders';
import { site } from '@/data/site';
import { getImage } from 'astro:assets';
import profilePhoto from '@/assets/profile.png';

const profileSrc = (await getImage({ src: profilePhoto, width: 120, height: 120 })).src;
const chips = ['Semántico', 'Performance', 'Astro / estático'] as const;
const skills = [
  'HTML',
  'CSS',
  'TypeScript',
  'JavaScript',
  'React',
  'Astro',
  'Tailwind CSS',
  'Motion',
  'Vite',
  'Git',
  'Accesibilidad',
  'Performance web',
  'SEO técnico',
  'Diseño responsivo',
] as const;
---

<AboutSectionClient
  client:visible
  profileSrc={profileSrc}
  profileAlt={`Retrato de ${site.name}`}
  heading="Implementación con criterio"
  body="Traduzco diseño y contenidos en páginas rápidas, accesibles y fáciles de mantener. HTML y CSS primero; JavaScript cuando suma. Trabajo con equipos o directo con marcas que necesitan claridad."
  chips={[...chips]}
  skills={[...skills]}
  placeholderLabel="PLACEHOLDER_BIO"
  placeholderBody={PLACEHOLDER_BIO}
  linkedin={site.social.linkedin}
  email={site.email}
  metrics={[...site.metrics]}
/>
