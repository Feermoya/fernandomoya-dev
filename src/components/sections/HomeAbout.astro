---
import AboutSectionClient from '@/components/react/AboutSectionClient';
import { site } from '@/data/site';
import { getImage } from 'astro:assets';
import profilePhoto from '@/assets/profile.png';

const profileSrc = (await getImage({ src: profilePhoto, width: 640, height: 640 })).src;
const chips: readonly string[] = [];
const aboutBody =
  'Si alguien entra a tu web, tiene que entender rápido qué hacés, por qué confiar y cómo contactarte.';
---

<AboutSectionClient
  client:visible
  profileSrc={profileSrc}
  profileAlt={`Retrato de ${site.name}`}
  heading="Diseño webs que explican mejor tu negocio"
  body={aboutBody}
  chips={[...chips]}
  linkedin={site.social.linkedin}
  email={site.email}
  metrics={[...site.metrics]}
/>
