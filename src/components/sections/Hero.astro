---
import HeroMotion from '@/components/react/HeroMotion';
import { site } from '@/data/site';
---

<section
  id="inicio"
  class="hero-root relative overflow-hidden border-b border-white/[0.08] pb-10 pt-8 sm:pb-12 sm:pt-10 lg:pb-14 lg:pt-12"
  aria-labelledby="hero-heading"
>
  <div class="hero-local-blobs" aria-hidden="true">
    <div class="hero-blob hero-blob--a"></div>
    <div class="hero-blob hero-blob--b"></div>
  </div>

  <div
    class="pointer-events-none absolute -left-24 top-8 h-48 w-48 rounded-[2rem] glass-pill opacity-40 sm:h-56 sm:w-56 lg:left-[-6%]"
    data-parallax="0.06"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute right-[-12%] top-24 hidden h-36 w-64 rounded-3xl glass-surface-sm opacity-45 shadow-glass-depth-sm sm:block lg:right-[-4%] lg:top-20"
    data-parallax="0.11"
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative z-10">
    <div class="hero-glass-card relative overflow-hidden rounded-2xl p-6 sm:p-8 lg:p-10">
      <div class="hero-mesh-corner" aria-hidden="true"></div>
      <div class="hero-grid-lines" aria-hidden="true"></div>

      <HeroMotion
        client:load
        eyebrow={`${site.name} · ${site.location}`}
        headline="Frontend claro, sitios que cargan y se mantienen"
        lead="Implementación sólida, performance medible y UI con criterio. Menos ruido, más entrega."
        pillA="Astro · Tailwind · Motion"
        pillB="Mendoza · Remoto"
        aside="Glass real, con Motion para guiar la lectura. Sin ruido visual."
      />
    </div>
  </div>
</section>
