---
import HeroCanvas from '@/components/react/HeroCanvas';
import HeroMotion from '@/components/react/HeroMotion';
import { site } from '@/data/site';
---

<section
  id="inicio"
  class="hero-root hero-immersive hero-root--tight relative flex min-h-[100svh] flex-col justify-between overflow-hidden border-b border-white/[0.08] pb-10 pt-16 sm:min-h-[100svh] sm:pt-18 sm:pb-14 lg:pt-20 lg:pb-16"
  aria-labelledby="hero-heading"
>
  <HeroCanvas client:load />

  <div class="container-page relative z-10">
    <div class="hero-content-wrap">
      <div class="hero-text-scrim" aria-hidden="true"></div>
      <HeroMotion
        client:load
        eyebrow="Diseño web · Desarrollo · Identidad digital"
        headlinePrefix="Si tu web no está"
        animatedWords={[
          "vendiendo",
          "cargando bien",
          "transmitiendo confianza",
          "generando consultas",
          "funcionando"
        ]}
        headlineSuffix="se puede arreglar."
        lead="Diseño sitios para negocios que quieren explicarse mejor, verse serios y conseguir más consultas."
        serviceLine=""
        pillA="Marcas y negocios"
        ctaPrimary="Hablar conmigo"
        ctaSecondary="Ver trabajos"
        ctaPrimaryHref={site.social?.whatsapp || '/'}
        ctaSecondaryHref="#proyectos"
      />
    </div>
  </div>
</section>
