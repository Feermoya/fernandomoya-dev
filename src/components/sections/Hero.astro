---
import HeroMotion from '@/components/react/HeroMotion';
import { site } from '@/data/site';
---

<section
  id="inicio"
  class="hero-root hero-root--tight relative overflow-hidden border-b border-white/[0.08] pb-8 pt-0 sm:pb-10 lg:-mt-10 lg:pb-12"
  aria-labelledby="hero-heading"
>
  <div class="hero-local-blobs" aria-hidden="true">
    <div class="hero-blob hero-blob--a"></div>
    <div class="hero-blob hero-blob--b"></div>
  </div>

  <div
    class="pointer-events-none absolute -left-24 top-8 h-48 w-48 rounded-[2rem] glass-pill opacity-40 sm:h-56 sm:w-56 lg:left-[-6%]"
    data-parallax="0.06"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute right-[-12%] top-24 hidden h-36 w-64 rounded-3xl glass-surface-sm opacity-45 shadow-glass-depth-sm sm:block lg:right-[-4%] lg:top-20"
    data-parallax="0.11"
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative z-10">
    <div class="hero-glass-card relative overflow-hidden rounded-2xl p-5 sm:p-7 lg:p-8">
      <div class="hero-mesh-corner" aria-hidden="true"></div>
      <div class="hero-grid-lines" aria-hidden="true"></div>

      <HeroMotion
        client:load
        eyebrow={`${site.name} · ${site.location}`}
        headline="Si tu web no está funcionando, se puede arreglar"
        lead="Trabajo con marcas y negocios que necesitan una web que se entienda, cargue bien y no genere problemas."
        serviceLine="Puede ser una web nueva o mejorar la que ya tenés."
        pillA="Marcas y negocios"
        ctaPrimary="Ver trabajos"
        ctaSecondary="Contame qué necesitás"
      />
    </div>
  </div>
</section>
