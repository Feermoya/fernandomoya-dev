---
import { getImage } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import ProjectsSectionClient from '@/components/react/ProjectsSectionClient';
import type { ProjectCardData } from '@/components/react/ProjectCardMotion';
import { getProjectCover } from '@/utils/images';
import { byOrderThenDate } from '@/utils/sort';

const all = await getCollection('projects');
const clients = all.filter((p) => p.data.kind === 'client').sort(byOrderThenDate);
const own = all.filter((p) => p.data.kind === 'own').sort(byOrderThenDate);

async function toCardData(p: CollectionEntry<'projects'>): Promise<ProjectCardData> {
  const cover = getProjectCover(p.data.cover);
  let coverSrc: string | null = null;
  if (cover) {
    /** 960×400 ≈ 2× respecto al slot de tarjeta para pantallas retina. */
    coverSrc = (await getImage({ src: cover, width: 960, height: 400 })).src;
  }
  return {
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    projectType: p.data.projectType,
    coverSrc,
    live: p.data.links.live,
    kindLabel: p.data.kind === 'client' ? 'Cliente' : 'Propio',
    kind: p.data.kind,
  };
}

const clientCards = await Promise.all(clients.map(toCardData));
const ownCards = await Promise.all(own.map(toCardData));
---

<ProjectsSectionClient
  client:visible
  groups={[
    { title: 'Clientes', items: clientCards },
    { title: 'Propios', items: ownCards },
  ]}
/>
