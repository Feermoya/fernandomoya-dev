---
import { getCollection } from 'astro:content';
import { byOrderThenDate } from '@/utils/sort';

const clients = (await getCollection('projects'))
  .filter((p) => p.data.kind === 'client')
  .sort(byOrderThenDate);
---

<section class="container-page pb-16 sm:pb-20" aria-labelledby="trust-heading" data-motion="fade">
  <div class="glass-surface rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
    <div class="max-w-2xl">
      <p class="text-eyebrow">Referencias</p>
      <h2 id="trust-heading" class="mt-2 text-xl font-semibold tracking-tight text-text sm:text-2xl">
        Clientes y organizaciones
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-muted sm:text-base">
        Sitios en producción con los que trabajé. En la grilla de proyectos tenés el detalle y el enlace al sitio
        en vivo.
      </p>
    </div>

    <ul class="mt-8 border-t border-white/35" aria-label="Clientes">
      {
        clients.map((c) => (
          <li class="flex flex-col gap-1 border-b border-white/20 py-3 last:border-b-0 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6 sm:py-3.5">
            <a
              class="text-sm font-medium text-text transition hover:text-accent"
              href={`#proyecto-${c.id}`}
            >
              {c.data.title}
            </a>
            <span class="text-xs text-muted sm:text-right">{c.data.projectType}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
