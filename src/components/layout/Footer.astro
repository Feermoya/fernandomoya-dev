---
import { site } from '@/data/site';

const year = new Date().getFullYear();

const quick = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#sobre-mi', label: 'Sobre mí' },
  { href: '#contacto', label: 'Contacto' },
] as const;
---

<footer class="footer-glass">
  <div class="container-page py-12 sm:py-14">
    <div class="grid gap-10 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-5">
        <p class="text-sm font-semibold tracking-tight text-text">{site.name}</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-muted">{site.tagline}</p>
        <p class="mt-4 text-xs text-muted">{site.location}</p>

        <div class="mt-6 space-y-2.5 text-sm">
          <p>
            <a class="link-underline-grow text-text" href={`mailto:${site.email}`}>
              {site.email}
            </a>
          </p>
          <p>
            <a
              class="link-underline-grow inline-flex items-center gap-2 text-muted hover:text-text"
              href={site.social.linkedin}
              rel="noreferrer"
              target="_blank"
            >
              <span class="glass-surface-sm inline-flex h-8 w-8 items-center justify-center rounded-md">
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true" class="fill-current">
                  <path
                    d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5ZM.5 23.5h4V8h-4v15.5ZM8 8h3.8v2.1h.1c.5-1 1.8-2.1 3.7-2.1 4 0 4.7 2.6 4.7 6v9.5h-4V15c0-1.6 0-3.7-2.2-3.7-2.2 0-2.5 1.7-2.5 3.4V23.5H8V8Z"
                  />
                </svg>
              </span>
              LinkedIn
            </a>
          </p>
        </div>
      </div>

      <div class="md:col-span-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">En esta página</p>
        <ul class="mt-4 space-y-2">
          {
            quick.map((l) => (
              <li>
                <a class="link-underline-grow text-sm text-text/90 hover:text-accent" href={l.href}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Consultas</p>
        <p class="mt-4 text-sm leading-relaxed text-muted">
          Proyectos nuevos, mejoras y mantenimiento. Incluí contexto en el primer mensaje.
        </p>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-white/[0.08] pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-muted">© {year} {site.name}</p>
      <p class="text-xs text-muted">Desarrollo frontend · {site.location}</p>
    </div>
  </div>
</footer>
