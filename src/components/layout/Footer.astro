---
import { site } from '@/data/site';

const year = new Date().getFullYear();
const mail = site.email;
const mailto = `mailto:${mail}`;
const linkedinUrl = import.meta.env.PUBLIC_LINKEDIN_URL?.trim() || site.social.linkedin;
const whatsappUrl = site.social.whatsapp;

const quick = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#sobre-mi', label: 'Sobre mí' },
  { href: '#contacto', label: 'Contacto' },
] as const;
---

<footer class="footer-glass">
  <div class="container-page py-8 sm:py-12 lg:py-14">
    <div class="grid grid-cols-1 gap-6 sm:gap-8 md:grid-cols-12 md:gap-10 lg:gap-12">
      <div class="md:col-span-5">
        <p class="text-sm font-semibold tracking-tight text-text">{site.name}</p>
        <p class="mt-1.5 max-w-sm text-sm leading-snug text-muted sm:mt-2 sm:leading-relaxed">{site.tagline}</p>
        <p class="mt-2 hidden text-xs text-muted sm:mt-3 sm:block">{site.location}</p>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:gap-5 md:contents md:gap-0">
        <div class="md:col-span-3">
          <p class="text-[10px] font-semibold uppercase tracking-[0.14em] text-muted sm:text-[11px]">En esta página</p>
          <ul class="footer-quick mt-2 sm:mt-3 md:space-y-2">
            {
              quick.map((l) => (
                <li>
                  <a class="link-underline-grow text-[13px] text-text/90 hover:text-accent sm:text-sm" href={l.href}>
                    {l.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="md:col-span-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.14em] text-muted sm:text-[11px]">Consultas</p>
          <p class="mt-2 text-[13px] leading-snug text-muted sm:mt-3 sm:text-sm sm:leading-relaxed">
            Proyectos nuevos o mejoras sobre sitios existentes. Escribime y lo vemos.
          </p>
        </div>
      </div>
    </div>

    <hr class="footer-dev-sep" />

    <div class="footer-dev-block">
      <div class="footer-dev-row">
        <span class="footer-dev-name">{site.name}</span>
        <span class="footer-dev-icons">
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-icon-link"
            aria-label="Fernando Moya en LinkedIn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" class="fill-current">
              <path
                d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5ZM.5 23.5h4V8h-4v15.5ZM8 8h3.8v2.1h.1c.5-1 1.8-2.1 3.7-2.1 4 0 4.7 2.6 4.7 6v9.5h-4V15c0-1.6 0-3.7-2.2-3.7-2.2 0-2.5 1.7-2.5 3.4V23.5H8V8Z"
              />
            </svg>
          </a>
          <a href={mailto} class="footer-icon-link" aria-label={`Enviar correo a ${mail}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-icon-link"
            aria-label="WhatsApp +54 9 261 576-0276"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              />
            </svg>
          </a>
        </span>
      </div>
      <p class="footer-dev-cta">Abierto a consultas y proyectos</p>
    </div>

    <div class="mt-6 border-t border-white/[0.08] pt-5 sm:mt-10 sm:pt-8 md:mt-12">
      <p class="text-center text-[11px] leading-snug text-muted sm:text-left sm:text-xs">
        © {year} {site.name}
        <span class="text-border-strong/40" aria-hidden="true"> · </span>
        Sitios web · {site.location}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-quick {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 640px) {
    .footer-quick {
      gap: 0.5rem;
    }
  }

  @media (max-width: 639.98px) {
    .footer-quick {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.25rem 0.75rem;
    }
  }

  .footer-dev-sep {
    border: none;
    height: 1px;
    margin: 1.25rem 0 1rem;
    background: rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 640px) {
    .footer-dev-sep {
      margin: 2rem 0 1.5rem;
    }
  }

  @media (min-width: 768px) {
    .footer-dev-sep {
      margin: 2.5rem 0 1.75rem;
    }
  }

  .footer-dev-block {
    max-width: 22rem;
  }

  .footer-dev-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.65rem;
  }

  .footer-dev-name {
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  @media (min-width: 640px) {
    .footer-dev-name {
      font-size: 1rem;
    }
  }

  .footer-dev-icons {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .footer-dev-icons {
      gap: 0.625rem;
    }
  }

  .footer-icon-link {
    display: inline-flex;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-icon-link:hover {
    color: var(--color-accent);
  }

  .footer-dev-cta {
    font-size: 0.6875rem;
    font-style: italic;
    line-height: 1.4;
    margin: 0.45rem 0 0;
    color: color-mix(in srgb, var(--color-muted) 92%, transparent);
  }

  @media (min-width: 640px) {
    .footer-dev-cta {
      font-size: 0.75rem;
      margin: 0.65rem 0 0;
    }
  }
</style>
